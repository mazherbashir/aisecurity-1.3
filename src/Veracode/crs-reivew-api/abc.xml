      <component added_date="2023-02-14 10:33:06 UTC" component_affects_policy_compliance="false" component_id="70fec3dc-6443-4c90-9cd0-362e21be2a32" description="" file_name="yargs-parser" library="yargs-parser" library_id="npm:yargs-parser::20.2.7:" max_cvss_score="5.3" sha1="" vendor="" version="20.2.7" vulnerabilities="1">
